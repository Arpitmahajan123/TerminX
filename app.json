{
  "expo": {
    "name": "AgriChain: Farm-to-Market AI C",
    "slug": "agrichain-farm-to-market-ai-c",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.agrichain-farm-to-market-ai-c"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.rork.agrichain_farm_to_market_ai_c"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AgriChain needs your location to show local weather, market prices, and crop advice for your area.",
          "locationWhenInUsePermission": "AgriChain needs your location to show local weather, market prices, and crop advice for your area."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}